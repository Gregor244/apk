# =========================
# HELPERS
# =========================

def as_float(v):
    try:
        return float(v)
    except:
        return None

def clamp(v, low, high):
    return max(low, min(v, high))

def sigmoid(x):
    try:
        return 1 / (1 + math.exp(-x))
    except:
        return 0.5

def parse_bar_time(ts):
    try:
        if not ts:
            return None
        return dt.datetime.fromisoformat(ts.replace("Z", "+00:00")).astimezone(NY)
    except:
        return None

def chunked(lst, size):
    for i in range(0, len(lst), size):
        yield lst[i:i + size]

# =========================
# TIME OF DAY RVOL
# =========================

def time_of_day_rvol(current_volume, avg_daily_volume, minutes_elapsed):
    session_minutes = 390
    fraction = minutes_elapsed / session_minutes
    expected_fraction = 0.12 * math.sqrt(max(fraction, 0.01))
    expected_volume = avg_daily_volume * expected_fraction
    return current_volume / max(expected_volume, 1)

# =========================
# FLOAT ROTATION
# =========================

def float_rotation_score(ticker, volume):
    fl = FLOAT_MAP.get(ticker)
    if not fl:
        return 0
    rotation = volume / max(fl * 1_000_000, 1)
    if rotation >= 10:
        return 35
    if rotation >= 5:
        return 25
    if rotation >= 2:
        return 15
    return rotation * 5

# =========================
# SPREAD FILTER
# =========================

def spread_score(bars):
    spreads = []
    for b in bars[-10:]:
        h = as_float(b.get("h"))
        l = as_float(b.get("l"))
        c = as_float(b.get("c"))
        if not h or not l or not c:
            continue
        spread = ((h - l) / max(c, 0.01)) * 100
        spreads.append(spread)
    if not spreads:
        return -10
    avg_spread = sum(spreads) / len(spreads)
    if avg_spread > 5:
        return -15
    if avg_spread > 3:
        return -8
    if avg_spread < 1:
        return 5
    return 0

# =========================
# PREMARKET HOD RECLAIM
# =========================

def premarket_hod_reclaim(bars):
    premarket_high = 0
    for b in bars:
        ts = b.get("t")
        if not ts:
            continue
        ts = dt.datetime.fromisoformat(ts.replace("Z", "+00:00")).astimezone(NY)
        if ts.hour < 9 or (ts.hour == 9 and ts.minute < 30):
            h = as_float(b.get("h"))
            if h:
                premarket_high = max(premarket_high, h)
    if premarket_high == 0:
        return 0
    current = as_float(bars[-1].get("c"))
    if not current:
        return 0
    distance = ((premarket_high - current) / current) * 100
    if current > premarket_high:
        return 25
    if distance < 1:
        return 15
    if distance < 2:
        return 8
    return 0

# =========================
# RELATIVE STRENGTH
# =========================

def relative_strength_score(bars, spy_bars):
    if not bars or not spy_bars:
        return 0
    s0 = as_float(bars[0].get("o"))
    s1 = as_float(bars[-1].get("c"))
    spy0 = as_float(spy_bars[0].get("o"))
    spy1 = as_float(spy_bars[-1].get("c"))
    if not all([s0, s1, spy0, spy1]):
        return 0
    stock_move = ((s1 - s0) / s0) * 100
    spy_move = ((spy1 - spy0) / spy0) * 100
    relative = stock_move - spy_move
    return relative * 2

# =========================
# VOLATILITY COMPRESSION
# =========================

def volatility_compression_score(bars):
    if len(bars) < 30:
        return 0
    ranges = []
    for b in bars[-30:]:
        h = as_float(b.get("h"))
        l = as_float(b.get("l"))
        c = as_float(b.get("c"))
        if not h or not l or not c:
            continue
        r = ((h - l) / max(c, 0.01)) * 100
        ranges.append(r)
    if not ranges:
        return 0
    recent = sum(ranges[-5:]) / 5
    older = sum(ranges[:20]) / 20
    if recent < older * 0.5:
        return 20
    if recent < older * 0.7:
        return 10
    return 0

# =========================
# LIQUIDITY SWEEP
# =========================

def liquidity_sweep_score(bars):
    if len(bars) < 10:
        return 0
    lows = []
    for b in bars[-10:-1]:
        l = as_float(b.get("l"))
        if l:
            lows.append(l)
    if not lows:
        return 0
    prior_low = min(lows)
    last = bars[-1]
    last_low = as_float(last.get("l"))
    last_close = as_float(last.get("c"))
    if not last_low or not last_close:
        return 0
    if last_low < prior_low and last_close > prior_low:
        return 15
    return 0

def liquidity_sweep_detector(bars):
    if len(bars) < 10:
        return 0
    sweeps = 0
    for b in bars[-10:]:
        o = as_float(b.get("o"))
        h = as_float(b.get("h"))
        l = as_float(b.get("l"))
        c = as_float(b.get("c"))
        if not all([o, h, l, c]):
            continue
        lower_wick = min(o, c) - l
        body = abs(c - o)
        if lower_wick > body * 2:
            sweeps += 1
    return sweeps * 3



# =========================
# API CONNECTIONS
# =========================

def api_get(endpoint, params=None):
    url = f"{BASE_URL}{endpoint}"
    r = session.get(url, params=params, timeout=30)
    if r.status_code == 401:
        raise RuntimeError("401 Unauthorized")
    if r.status_code == 429:
        time.sleep(3)
    if r.status_code >= 400:
        raise RuntimeError(r.text)
    time.sleep(REQUEST_SLEEP)
    return r.json()

def get_stock_bars(symbols, timeframe, start_iso, end_iso):
    all_bars = {}
    for chunk in chunked(symbols, 150):
        joined = ",".join(chunk)
        try:
            data = api_get("/stocks/bars", {
                "symbols": joined,
                "timeframe": timeframe,
                "start": start_iso,
                "end": end_iso,
                "feed": "iex",
                "adjustment": "raw",
                "limit": 10000
            })
        except:
            data = api_get("/stocks/bars", {
                "symbols": joined,
                "timeframe": timeframe,
                "start": start_iso,
                "end": end_iso,
                "feed": "delayed_sip",
                "adjustment": "raw",
                "limit": 10000
            })
        bars = data.get("bars", {})
        all_bars.update(bars)
    return all_bars

# =========================
# FINNHUB FETCH
# =========================

def finnhub_get(endpoint, params=None):
    if params is None:
        params = {}
    params["token"] = FINNHUB_KEY
    url = FINNHUB_URL + endpoint
    r = requests.get(url, params=params, timeout=20)
    if r.status_code >= 400:
        return None
    try:
        return r.json()
    except:
        return None

def get_float_and_sector(ticker):
    if ticker in FLOAT_MAP and ticker in SECTOR_MAP:
        return
    try:
        data = finnhub_get("/stock/profile2", {"symbol": ticker})
        if not data:
            return
        shares = data.get("shareOutstanding")
        if shares:
            FLOAT_MAP[ticker] = float(shares)
        sector = data.get("finnhubIndustry") or "UNKNOWN"
        SECTOR_MAP[ticker] = sector
    except:
        pass

def build_float_sector_cache(tickers):
    print("\nBUILDING FLOAT / SECTOR CACHE...")
    updated = 0
    for i, ticker in enumerate(tickers):
        if ticker in FLOAT_MAP and ticker in SECTOR_MAP:
            continue
        get_float_and_sector(ticker)
        updated += 1
        time.sleep(0.25)
        if i % 25 == 0:
            print(f"CACHE {i}/{len(tickers)}")
    save_json_cache(FLOAT_CACHE_FILE, FLOAT_MAP)
    save_json_cache(SECTOR_CACHE_FILE, SECTOR_MAP)
    print(f"\nCACHE DONE ({updated} updated)")

def get_upcoming_earnings(tickers_list):
    """
    Pobiera wyniki finansowe na dziś i jutro z Finnhub,
    filtruje po liście TICKERS i dołącza statystyki spółki.
    """
    # Używamy strefy ET (Nowy Jork) dla spójności kalendarza giełdowego
    today = dt.datetime.now(NY).date()
    tomorrow = today + dt.timedelta(days=1)
    
    start_date = today.strftime('%Y-%m-%d')
    end_date = tomorrow.strftime('%Y-%m-%d')
    
    print(f"\n📡 POBIERANIE WYNIKÓW FINANSOWYCH ({start_date} do {end_date})...")
    
    # Endpoint Finnhub
    params = {"from": start_date, "to": end_date}
    
    try:
        data = finnhub_get("/calendar/earnings", params)
    except Exception as e:
        print(f"⚠️ Błąd pobierania kalendarza wyników: {e}")
        return []

    earnings_list = []
    
    if data and "earningsCalendar" in data:
        for item in data["earningsCalendar"]:
            ticker = item.get("symbol")
            
            # Filtrujemy tylko spółki, które skanujesz, aby odsiać śmieci
            if ticker in tickers_list:
                date = item.get("date")
                eps_est = item.get("epsEstimate")
                rev_est = item.get("revenueEstimate")
                
                # Pobranie danych strukturalnych z lokalnego cache
                float_shares = FLOAT_MAP.get(ticker, 0)
                sector = SECTOR_MAP.get(ticker, "UNKNOWN")
                
                earnings_list.append({
                    "ticker": ticker,
                    "date": date,
                    "eps_est": eps_est if eps_est else 0.0,
                    "rev_est": rev_est if rev_est else 0,
                    "float": float_shares,
                    "sector": sector
                })
                
    return earnings_list
# =========================
# MARKET REGIME
# =========================

def market_regime():
    now = dt.datetime.now(NY)
    h = now.hour
    if 9 <= h < 11:
        return "MOMENTUM"
    if 11 <= h < 14:
        return "CHOP"
    return "POWER"

# =========================
# FLOAT SCORING
# =========================

def float_score(ticker):
    fl = FLOAT_MAP.get(ticker)
    if not fl:
        return 0
    if fl < 5:
        return 35
    if fl < 10:
        return 25
    if fl < 20:
        return 18
    if fl < 50:
        return 10
    if fl < 100:
        return 5
    return -5

# =========================
# NEWS NLP
# =========================

def news_nlp_score(ticker):
    score = 0
    fake_news = random.choice(["ai partnership", "contract", "guidance raised", "offering", "none"])
    txt = fake_news.lower()
    for w in BULLISH_NEWS:
        if w in txt:
            score += 8
    for w in BEARISH_NEWS:
        if w in txt:
            score -= 10
    return score

# =========================
# SECTOR SYMPATHY
# =========================

def sector_sympathy_score(ticker, movers):
    sector = SECTOR_MAP.get(ticker)
    if not sector:
        return 0
    same_sector = 0
    for other in movers:
        if other == ticker:
            continue
        other_sector = SECTOR_MAP.get(other)
        if other_sector == sector:
            same_sector += 1
    return same_sector * 4

# =========================
# DARK POOL PROXY
# =========================

def dark_pool_proxy(bars):
    if len(bars) < 20:
        return {"score": 0, "hidden_buying": False}
    tight = 0
    holds = 0
    for b in bars[-20:]:
        o = as_float(b.get("o"))
        h = as_float(b.get("h"))
        l = as_float(b.get("l"))
        c = as_float(b.get("c"))
        v = as_float(b.get("v"))
        if not all([o, h, l, c, v]):
            continue
        rng = (h - l) / max(c, 0.01)
        if v > 50000 and rng < 0.015:
            tight += 1
        if c >= o * 0.998:
            holds += 1
    score = tight * 2 + holds
    return {"score": round(score, 2), "hidden_buying": (tight >= 5)}

# =========================
# MORNING RUNNER
# =========================

def morning_runner_detector(bars):
    pre = []
    for b in bars:
        ts = parse_bar_time(b.get("t"))
        if not ts:
            continue
        if dt.time(5, 0) <= ts.time() < dt.time(9, 30):
            pre.append(b)
    if len(pre) < 5:
        return {"runner": False, "score": 0}
    total_vol = 0
    greens = 0
    first = None
    last = None
    for i, b in enumerate(pre):
        o = as_float(b.get("o"))
        c = as_float(b.get("c"))
        v = as_float(b.get("v"))
        if not all([o, c, v]):
            continue
        total_vol += v
        if c > o:
            greens += 1
        if i == 0:
            first = c
        last = c
    if not first or not last:
        return {"runner": False, "score": 0}
    move = ((last - first) / max(first, 0.01)) * 100
    score = greens * 0.8 + move * 1.5
    if total_vol > 1000000:
        score += 15
    return {"runner": score >= 20, "score": round(score, 2)}

# =========================
# LIGHT PREFILTER
# =========================

def prefilter(target_date, target_time, tickers, spy_bars=None):
    local_dt = dt.datetime.combine(target_date, target_time, tzinfo=NY)
    start_dt = local_dt.replace(hour=5, minute=0, second=0, microsecond=0)



    intraday = get_stock_bars(tickers, "1Min", start_dt.isoformat(), local_dt.isoformat())
    candidates = []

    for ticker, bars in intraday.items():
        if not bars:
            continue
        first = as_float(bars[0].get("o"))
        last = as_float(bars[-1].get("c"))
        if not first or not last:
            continue
        if last < MIN_PRICE or last > MAX_PRICE:
            continue

        total_volume = sum([as_float(b.get("v")) or 0 for b in bars])
        if total_volume < 200000:
            continue

        move_pct = ((last - first) / max(first, 0.01)) * 100
        rvol = total_volume / 1000000

        greens = 0
        for b in bars[-30:]:
            o = as_float(b.get("o"))
            c = as_float(b.get("c"))
            if o and c and c > o:
                greens += 1

        highs = [as_float(b.get("h")) for b in bars[-20:] if as_float(b.get("h"))]
        lows = [as_float(b.get("l")) for b in bars[-20:] if as_float(b.get("l"))]
        if not highs or not lows:
            continue

        compression = (max(highs) - min(lows)) / max(last, 0.01)
        score = 0

        # Core Original Factors
        score += max(move_pct, 0) * 2
        score += greens * 0.7
        score += rvol * 6

        if compression < 0.03:
            score += 12

        morning = morning_runner_detector(bars)
        score += morning["score"] * 0.5

        recent_high = max(highs)
        distance = ((recent_high - last) / max(last, 0.01)) * 100
        if distance < 2:
            score += 15

        # New Institutional Momentum Filters (codess.docx)
        minutes_elapsed = ((target_time.hour * 60 + target_time.minute) - (9 * 60 + 30))
        minutes_elapsed = max(minutes_elapsed, 1)
        tod_rvol = time_of_day_rvol(total_volume, 1000000, minutes_elapsed)
        score += tod_rvol * 8

        score += float_rotation_score(ticker, total_volume)
        score += spread_score(bars)
        score += premarket_hod_reclaim(bars)
        
        if spy_bars is not None:
            score += relative_strength_score(bars, spy_bars)
            
        score += volatility_compression_score(bars)
        score += liquidity_sweep_score(bars)
        score += float_score(ticker)
        score += sector_sympathy_score(ticker, tickers)

        candidates.append({
            "ticker": ticker,
            "score": round(score, 2),
            "move_pct": round(move_pct, 2),
            "rvol": round(rvol, 2),
            "compression": round(compression, 4)
        })

    if not candidates:
        return []

    df = pd.DataFrame(candidates)
    df = df.sort_values(["score", "rvol"], ascending=False)

    print("\n🔥 PREFILTER")
    print(df.head(25).to_string(index=False))
    return df.head(25)["ticker"].tolist()

# =========================
# INTRADAY ANALYSIS
# =========================

def analyze_intraday(bars):
    if len(bars) < 20:
        return None
    vols = []
    closes = []
    highs = []
    lows = []
    cumulative_pv = 0
    cumulative_vol = 0
    spike = False
    early_spike = False
    strong_red = False
    max_spike = 0
    red_streak = 0
    late_vol = 0
    total_vol = 0

    for i, b in enumerate(bars):
        o = as_float(b.get("o"))
        h = as_float(b.get("h"))
        l = as_float(b.get("l"))
        c = as_float(b.get("c"))
        v = as_float(b.get("v"))
        if not all([o, h, l, c, v]):
            continue
        vols.append(v)
        closes.append(c)
        highs.append(h)
        lows.append(l)
        total_vol += v

        typical = (h + l + c) / 3
        cumulative_pv += (typical * v)
        cumulative_vol += v
        vwap = cumulative_pv / cumulative_vol

        avg_vol = sum(vols[-15:]) / max(len(vols[-15:]), 1)
        ratio = v / avg_vol if avg_vol else 0
        max_spike = max(max_spike, ratio)

        if ratio > 2.5:
            spike = True
            if i < 45:
                early_spike = True
        if c < o:
            red_streak += 1
        else:
            red_streak = 0
        if red_streak >= 5:
            strong_red = True
        if i >= len(bars) * 0.7:
            late_vol += v

    day_high = max(highs)
    day_low = min(lows)
    final_close = closes[-1]
    first_close = closes[0]
    day_range = max(day_high - day_low, 0.01)

    close_strength = (final_close - day_low) / day_range
    trend_pct = ((final_close - first_close) / max(first_close, 0.01)) * 100
    late_vol_ratio = late_vol / max(total_vol, 1)
    vwap_extension = ((final_close - vwap) / max(vwap, 0.01)) * 100
    dump_ratio = (day_high - final_close) / day_range
    recent_high = max(highs[-20:])
    breakout_proximity = ((recent_high - final_close) / max(final_close, 0.01)) * 100
    compression = (max(highs[-10:]) - min(lows[-10:])) / max(final_close, 0.01)

    pre_breakout = (
        breakout_proximity < 2
        and compression < 0.03
        and close_strength > 0.7
        and trend_pct > 2
    )
    relative_strength = close_strength * max(trend_pct, 0)

    return {
        "spike": spike, "early_spike": early_spike, "strong_red": strong_red,
        "max_spike": round(max_spike, 2), "close_strength": round(close_strength, 2),
        "trend_pct": round(trend_pct, 2), "late_vol_ratio": round(late_vol_ratio, 2),
        "vwap_extension": round(vwap_extension, 2), "dump_ratio": round(dump_ratio, 2),
        "pre_breakout": pre_breakout, "breakout_proximity": round(breakout_proximity, 2),
        "compression": round(compression, 4), "relative_strength": round(relative_strength, 2)
    }

# =========================
# ML MODEL
# =========================

def ml_probability_model(ticker, analysis, dp, morning, sector_score, news_score, sweep_score, rvol, bars):
    score = 0
    score += (analysis["max_spike"] * 5)
    score += (analysis["close_strength"] * 25)
    score += (max(analysis["trend_pct"], 0) * 2)
    score += spread_score(bars)
    score += (analysis["late_vol_ratio"] * 22)
    score += (max(analysis["vwap_extension"], 0) * 4)

    if analysis["pre_breakout"]:
        score += 18

    score += (max(0, 2 - analysis["breakout_proximity"]) * 4)
    score += (max(0, 1 - analysis["compression"]) * 10)
    score += (morning["score"] * 0.7)
    score += dp["score"]
    score += float_score(ticker)
    score += sector_score
    score += news_score
    score += sweep_score
    score += rvol * 4

    if dp["hidden_buying"]:
        score += 12

    score -= (analysis["dump_ratio"] * 25)
    if analysis["strong_red"]:
        score -= 20

    regime = market_regime()
    if regime == "MOMENTUM":
        score *= 1.15
    elif regime == "POWER":
        score *= 1.08
    elif regime == "CHOP":
        score *= 0.85

    breakout_prob = sigmoid((score - 55) / 10) * 100
    continuation_prob = sigmoid((score - 65) / 10) * 100
    fail_prob = 100 - breakout_prob

    return {
        "score": round(score, 2),
        "breakout_probability": round(breakout_prob, 2),
        "continuation_probability": round(continuation_prob, 2),
        "fail_probability": round(fail_prob, 2)
    }

# =========================
# MAIN SCAN
# =========================

def run_scan(date_str, time_str, tickers):
    target_date = dt.datetime.strptime(date_str, "%Y-%m-%d").date()
    hh, mm = map(int, time_str.split(":"))
    target_time = dt.time(hh, mm)

    local_dt = dt.datetime.combine(target_date, target_time, tzinfo=NY)
    start_dt = local_dt.replace(hour=5, minute=0, second=0, microsecond=0)

    # SPY Data Retrieval
    try:
        spy_bars_dict = get_stock_bars(["SPY"], "1Min", start_dt.isoformat(), local_dt.isoformat())
        spy_bars = spy_bars_dict.get("SPY", [])
    except:
        spy_bars = []

    # Prefilter Execution
    filtered = prefilter(target_date, target_time, tickers, spy_bars)
    if not filtered:
        print("\nNO PREFILTER MATCHES")
        return pd.DataFrame()

    intraday = get_stock_bars(filtered, "1Min", start_dt.isoformat(), local_dt.isoformat())
    results = []
    leaders = {}

    for ticker in filtered:
        bars = intraday.get(ticker, [])
        if not bars:
            continue
        first = as_float(bars[0].get("c"))
        last = as_float(bars[-1].get("c"))
        if first and last:
            leaders[ticker] = ((last - first) / first) * 100

    for ticker, bars in intraday.items():
        if not bars:
            continue
        last_price = as_float(bars[-1].get("c"))
        if not last_price or last_price < MIN_PRICE or last_price > MAX_PRICE:
            continue

        analysis = analyze_intraday(bars)
        if not analysis:
            continue

        total_vol = sum([as_float(b.get("v")) or 0 for b in bars])
        rvol = total_vol / 1000000

        dp = dark_pool_proxy(bars)
        morning = morning_runner_detector(bars)
        news_score = news_nlp_score(ticker)
        sector_score = sector_sympathy_score(ticker, leaders)
        sweep_score = liquidity_sweep_detector(bars)

        ml = ml_probability_model(
            ticker, analysis, dp, morning, sector_score, news_score, sweep_score, rvol, bars
        )

        results.append({
            "ticker": ticker, "price": round(last_price, 2), "ml_score": ml["score"],
            "breakout": ml["breakout_probability"], "continuation": ml["continuation_probability"],
            "fail": ml["fail_probability"], "runner": morning["runner"], "pre_bo": analysis["pre_breakout"],
            "hidden_buy": dp["hidden_buying"], "trend": analysis["trend_pct"], "rvol": round(rvol, 2),
            "sector": round(sector_score, 2), "news": round(news_score, 2)
        })

    df = pd.DataFrame(results)
    if df.empty:
        return df
    return df.sort_values(["breakout", "continuation", "ml_score"], ascending=False)

# =========================
# PRETTY PRINT
# =========================

def print_results(df):
    if df.empty:
        print("\nNO RESULTS\n")
        return

    print("\n" + "=" * 90)
    print("🔥 TOP BREAKOUT CANDIDATES")
    print("=" * 90)
    print(df.head(5)[[
        "ticker", "price", "breakout", "continuation", "ml_score", 
        "trend", "rvol", "runner", "pre_bo", "hidden_buy"
    ]].to_string(index=False))

    print("\n" + "=" * 90)
    print("⚡ PRE-BREAKOUT SETUPS")
    print("=" * 90)
    pre = df[df["pre_bo"] == True].head(5)
    if pre.empty:
        print("No strong pre-breakout setups")
    else:
        print(pre[["ticker", "breakout", "continuation", "trend", "rvol", "sector", "news"]].to_string(index=False))


