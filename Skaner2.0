# =========================
# CACHE HELPERS
# =========================

def load_json_cache(path):
    if not os.path.exists(path):
        return {}
    try:
        with open(path, "r") as f:
            return json.load(f)
    except:
        return {}

def save_json_cache(path, data):
    try:
        with open(path, "w") as f:
            json.dump(data, f)
    except:
        pass

