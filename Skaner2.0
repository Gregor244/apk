# PROFESSIONAL PRE-EARNINGS RADAR v4.0
# ZASTĄP STARE print_earnings_radar()
# =========================================================

from tabulate import tabulate
from colorama import Fore, Style, init

init(autoreset=True)

# =========================================================
# MOCK INSTITUTIONAL DATA
# (Później podmień na API)
# =========================================================

def mock_iv_rank():
    return round(random.uniform(20, 100), 2)

def mock_expected_move():
    return round(random.uniform(3, 15), 2)

def mock_short_interest():
    return round(random.uniform(1, 25), 2)

def mock_days_to_cover():
    return round(random.uniform(0.5, 12), 2)

def mock_beat_rate():
    return random.randint(45, 95)

def mock_avg_earnings_move():
    return round(random.uniform(2, 14), 2)

def mock_revision():
    return random.choice([
        "UP",
        "DOWN",
        "FLAT"
    ])

def mock_options_flow():
    return random.choice([
        "BULLISH CALL FLOW",
        "AGGRESSIVE SWEEPS",
        "PUT HEDGE",
        "NEUTRAL",
        "INSTITUTIONAL BUYING"
    ])

# =========================================================
# SQUEEZE SCORE
# =========================================================

def squeeze_score(short_interest, float_size):

    score = 0

    if short_interest > 25:
        score += 30

    elif short_interest > 15:
        score += 20

    elif short_interest > 8:
        score += 10

    if float_size < 20:
        score += 20

    elif float_size < 50:
        score += 10

    return score

# =========================================================
# EARNINGS SCORE ENGINE
# =========================================================

def earnings_score(stock):

    score = 0

    # IV RANK
    if stock["iv_rank"] > 80:
        score += 20

    elif stock["iv_rank"] > 60:
        score += 12

    elif stock["iv_rank"] > 40:
        score += 6

    # SHORT INTEREST
    if stock["short_interest"] > 20:
        score += 20

    elif stock["short_interest"] > 10:
        score += 10

    # BEAT RATE
    if stock["beat_rate"] > 80:
        score += 18

    elif stock["beat_rate"] > 65:
        score += 10

    # EXPECTED MOVE
    if stock["expected_move"] > 10:
        score += 18

    elif stock["expected_move"] > 7:
        score += 10

    elif stock["expected_move"] > 5:
        score += 5

    # FLOAT
    if stock["float"] < 20:
        score += 18

    elif stock["float"] < 50:
        score += 10

    # REVISIONS
    if stock["revision"] == "UP":
        score += 15

    elif stock["revision"] == "DOWN":
        score -= 10

    # OPTIONS FLOW
    flow = stock["options_flow"]

    if "CALL" in flow:
        score += 15

    if "SWEEPS" in flow:
        score += 12

    if "BUYING" in flow:
        score += 10

    # AVG MOVE
    if stock["avg_move"] > 10:
        score += 15

    elif stock["avg_move"] > 6:
        score += 8

    # SQUEEZE
    score += squeeze_score(
        stock["short_interest"],
        stock["float"]
    )

    return round(min(score, 100), 2)

# =========================================================
# SETUP GRADE
# =========================================================

def setup_grade(score):

    if score >= 90:
        return "A+"

    elif score >= 75:
        return "A"

    elif score >= 60:
        return "B"

    elif score >= 45:
        return "C"

    return "D"

# =========================================================
# COLOR FORMAT
# =========================================================

def color_grade(g):

    if g == "A+":
        return Fore.GREEN + g + Style.RESET_ALL

    if g == "A":
        return Fore.LIGHTGREEN_EX + g + Style.RESET_ALL

    if g == "B":
        return Fore.YELLOW + g + Style.RESET_ALL

    if g == "C":
        return Fore.LIGHTRED_EX + g + Style.RESET_ALL

    return Fore.RED + g + Style.RESET_ALL

# =========================================================
# PROFESSIONAL PRE-EARNINGS RADAR
# =========================================================

def print_earnings_radar(earnings_list):

    if not earnings_list:
        print("\nNO EARNINGS DATA")
        return

    enhanced = []

    for e in earnings_list:

        stock = {
            "ticker": e["ticker"],
            "date": e["date"],
            "eps_est": e["eps_est"],
            "rev_est": round(e["rev_est"] / 1_000_000, 2),
            "float": round(e["float"] / 1_000_000, 2),

            # Institutional Metrics
            "iv_rank": mock_iv_rank(),
            "expected_move": mock_expected_move(),
            "short_interest": mock_short_interest(),
            "days_to_cover": mock_days_to_cover(),
            "beat_rate": mock_beat_rate(),
            "avg_move": mock_avg_earnings_move(),
            "revision": mock_revision(),
            "options_flow": mock_options_flow(),

            "sector": e["sector"]
        }

        stock["earnings_score"] = earnings_score(stock)
        stock["setup_grade"] = setup_grade(
            stock["earnings_score"]
        )

        enhanced.append(stock)

    df = pd.DataFrame(enhanced)

    df = df.sort_values(
        ["earnings_score", "iv_rank"],
        ascending=False
    )

    df["setup_grade"] = df["setup_grade"].apply(color_grade)

    print("\n")
    print("=" * 220)
    print("🔥 PROFESSIONAL PRE-EARNINGS RADAR")
    print("=" * 220)

    cols = [
        "ticker",
        "date",
        "eps_est",
        "rev_est",
        "float",
        "iv_rank",
        "expected_move",
        "short_interest",
        "days_to_cover",
        "beat_rate",
        "avg_move",
        "revision",
        "options_flow",
        "earnings_score",
        "setup_grade"
    ]

    print(
        tabulate(
            df[cols],
            headers="keys",
            tablefmt="fancy_grid",
            showindex=False
        )
    )

    print("\n")
    print("=" * 220)
    print("🚀 TOP EARNINGS SETUPS")
    print("=" * 220)

    top = df.head(10)

    for _, r in top.iterrows():

        print(
            f"{r['ticker']} | "
            f"Score={r['earnings_score']} | "
            f"IV={r['iv_rank']} | "
            f"Short={r['short_interest']}% | "
            f"Move={r['expected_move']}% | "
            f"BeatRate={r['beat_rate']}% | "
            f"Flow={r['options_flow']}"
        )

    print("\n")
    print("=" * 220)
    print("📌 LEGEND")
    print("=" * 220)

    print("IV Rank         = implied volatility vs 52w range")
    print("Expected Move   = options implied earnings move")
    print("Short Interest  = squeeze probability")
    print("Days To Cover   = short pressure")
    print("Beat Rate       = historical EPS beat frequency")
    print("Avg Move        = historical post earnings move")
    print("Revision        = analyst estimate revisions")
    print("Options Flow    = institutional positioning")
    print("Earnings Score  = composite breakout probability")
    print("Setup Grade     = overall setup quality")



